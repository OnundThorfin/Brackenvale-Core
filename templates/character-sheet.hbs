<form class="brackenvale-minimal-sheet {{cssClass}}" autocomplete="off">
  <header class="brackenvale-minimal-header">
    <h1>Brackenvale</h1>
  </header>

  <main class="brackenvale-minimal-body">
    <div class="brackenvale-minimal-portrait">
      <img
        src="{{actor.img}}"
        data-edit="img"
        alt="{{actor.name}}"
      >
    </div>

    <section class="brackenvale-minimal-identity">
      <label for="brackenvale-character-name">Character Name</label>
      <input
        id="brackenvale-character-name"
        type="text"
        name="name"
        value="{{actor.name}}"
      >

      <div class="brackenvale-render-success">
        The Brackenvale character sheet is rendering successfully.
      </div>
    </section>
  </main>
</form>
