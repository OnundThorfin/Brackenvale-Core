<form class="brackenvale-art-sheet {{cssClass}}" autocomplete="off">
  <nav class="brackenvale-page-tabs" aria-label="Character sheet pages">
    <div class="brackenvale-page-buttons">
      {{#each pages}}
        <button
          type="button"
          class="{{#if active}}active{{/if}}"
          data-page="{{page}}"
        >
          {{page}}
        </button>
      {{/each}}
    </div>

    {{#if isGM}}
      <div class="brackenvale-layout-tools">
        <button type="button" data-action="toggle-calibration">
          Calibrate
        </button>
        <button type="button" data-action="export-layout">
          Export Page JSON
        </button>
        <span class="brackenvale-calibration-status" aria-live="polite">
          No field selected
        </span>
      </div>
    {{/if}}
  </nav>

  {{#each pages}}
    <div
      class="brackenvale-art-page {{#if active}}active{{/if}}"
      data-page="{{page}}"
    >
      <img
        class="brackenvale-page-art"
        src="{{art}}"
        alt=""
        draggable="false"
      >

      <div class="brackenvale-page-fields">
        {{#each components}}
          {{#if isTextField}}
            <input
              class="overlay-field {{className}}"
              type="{{inputType}}"
              name="{{name}}"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{#if readonly}}readonly{{/if}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isItemSummary}}
            <input
              class="overlay-field {{className}} item-summary-field"
              type="text"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              title="Double-click to open the native D&D item"
              data-item-id="{{itemId}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              readonly
            >
          {{/if}}

          {{#if isCheckboxField}}
            <input
              class="overlay-field {{className}}"
              type="checkbox"
              name="{{name}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{checked checked}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isRollRow}}
            <div
              class="overlay-field {{className}} proficiency-rank-{{proficiencyRank}}"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
            >
              <button
                type="button"
                class="ability-roll-proficiency"
                aria-label="Change {{label}} proficiency"
                title="{{#if proficiencyEditable}}Click to cycle proficiency{{else}}Unlock the sheet to change proficiency{{/if}}"
                data-action="cycle-proficiency"
                data-path="{{proficiencyPath}}"
                data-rank="{{proficiencyRank}}"
                data-maximum-rank="{{maximumRank}}"
                {{#unless proficiencyEditable}}disabled{{/unless}}
              ></button>

              <button
                type="button"
                class="ability-roll-button"
                aria-label="{{label}}"
                title="Roll {{label}}"
                data-roll-type="{{rollType}}"
                data-roll-key="{{rollKey}}"
              >
                <span class="ability-roll-modifier">{{modifierValue}}</span>
              </button>
            </div>
          {{/if}}

          {{#if isHitDiceSummary}}
            <div
              class="overlay-field hit-dice-summary"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              <button
                type="button"
                class="hit-dice-denomination"
                data-action="edit-hit-dice-class"
                data-item-id="{{itemId}}"
                title="Open class and Hit Dice settings"
                {{#unless itemId}}disabled{{/unless}}
              >{{denomination}}</button>

              <button
                type="button"
                class="hit-dice-total"
                data-action="edit-hit-dice-class"
                data-item-id="{{itemId}}"
                title="Total Hit Dice comes from class level"
                {{#unless itemId}}disabled{{/unless}}
              >{{total}}</button>

              <input
                class="hit-dice-used"
                type="number"
                min="0"
                max="{{total}}"
                value="{{used}}"
                data-action="update-hit-dice-used"
                data-item-id="{{itemId}}"
                data-item-path="{{usedPath}}"
                aria-label="Used Hit Dice"
                title="Used Hit Dice"
                {{#unless editable}}disabled{{/unless}}
              >
            </div>
          {{/if}}

          {{#if isDeathSaveBubble}}
            <button
              type="button"
              class="overlay-field death-save-bubble {{#if filled}}filled{{/if}}"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              data-action="set-death-save"
              data-path="{{path}}"
              data-value="{{value}}"
              aria-label="{{label}}"
              title="{{label}}"
              {{#unless editable}}disabled{{/unless}}
            ></button>
          {{/if}}

          {{#if isWeaponTable}}
            <div
              class="overlay-field weapon-toolbar"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              {{#each weapons}}
                <div class="weapon-toolbar-row {{#unless id}}empty{{/unless}} {{#unless equipped}}unequipped{{/unless}}">
                  <button
                    type="button"
                    class="weapon-toolbar-cell weapon-name"
                    data-action="edit-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Open weapon item{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{name}}</button>

                  <button
                    type="button"
                    class="weapon-toolbar-cell weapon-attack"
                    data-action="use-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Use weapon attack{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{attack}}</button>

                  <button
                    type="button"
                    class="weapon-toolbar-cell weapon-damage"
                    data-action="roll-weapon-damage"
                    data-item-id="{{id}}"
                    title="{{#if id}}Use weapon damage workflow{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{damage}}</button>

                  <button
                    type="button"
                    class="weapon-toolbar-cell weapon-mastery"
                    data-action="show-weapon-mastery"
                    data-item-id="{{id}}"
                    data-mastery-name="{{mastery}}"
                    data-mastery-reference="{{masteryReference}}"
                    title="{{#if masteryReference}}Open {{mastery}} rules{{else}}No mastery rules entry available{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{mastery}}</button>

                  <div class="weapon-condition-overlay" aria-label="{{#if id}}Weapon condition{{/if}}">
                    {{#each conditionDots}}
                      <button
                        type="button"
                        class="weapon-condition-hitbox {{#if filled}}filled{{/if}}"
                        data-action="set-weapon-condition"
                        data-item-id="{{../id}}"
                        data-value="{{value}}"
                        aria-label="Set weapon condition to {{value}}"
                        {{#unless ../id}}disabled{{/unless}}
                      ></button>
                    {{/each}}
                  </div>
                </div>
              {{/each}}
            </div>
          {{/if}}

          {{#if isEquipmentRegion}}
            <div
              class="overlay-field equipment-region equipment-region-{{region}}"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              data-equipment-drop-zone="{{region}}"
              aria-label="{{label}}"
              title="Drop items here"
            >
              {{#if armorItem}}
                <div class="equipment-row equipment-defense-row equipment-armor-row">
                  <button
                    type="button"
                    class="equipment-item-name"
                    draggable="true"
                    data-equipment-item-id="{{armorItem.id}}"
                    data-item-id="{{armorItem.id}}"
                    title="Double-click to open item"
                  >{{armorItem.name}}</button>
                  {{#if editable}}
                    <button type="button" class="equipment-delete" data-action="delete-equipment-item" data-item-id="{{armorItem.id}}" title="Delete {{armorItem.name}}">×</button>
                  {{/if}}
                </div>
              {{/if}}

              {{#if shieldItem}}
                <div class="equipment-row equipment-defense-row equipment-shield-row">
                  <button
                    type="button"
                    class="equipment-item-name"
                    draggable="true"
                    data-equipment-item-id="{{shieldItem.id}}"
                    data-item-id="{{shieldItem.id}}"
                    title="Double-click to open item"
                  >{{shieldItem.name}}</button>
                  {{#if editable}}
                    <button type="button" class="equipment-delete" data-action="delete-equipment-item" data-item-id="{{shieldItem.id}}" title="Delete {{shieldItem.name}}">×</button>
                  {{/if}}
                </div>
              {{/if}}

              {{#each items}}
                <div class="equipment-row">
                  <button
                    type="button"
                    class="equipment-item-name"
                    draggable="true"
                    data-equipment-item-id="{{id}}"
                    data-item-id="{{id}}"
                    title="Double-click to open item"
                  >{{name}}</button>
                  {{#if ../editable}}
                    <button type="button" class="equipment-delete" data-action="delete-equipment-item" data-item-id="{{id}}" title="Delete {{name}}">×</button>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          {{/if}}

          {{#if isEquippedDefenseName}}
            <button
              type="button"
              class="overlay-field equipped-defense-name"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              data-item-id="{{itemId}}"
              aria-label="{{label}}"
              title="{{#if itemId}}Double-click to open item{{/if}}"
              {{#unless itemId}}disabled{{/unless}}
            >{{value}}</button>
          {{/if}}

          {{#if isAbilityScore}}
            <input
              class="overlay-field ability-score-field"
              type="number"
              name="{{scoreName}}"
              value="{{scoreValue}}"
              style="{{scoreStyle}}"
              aria-label="{{label}} score"
              data-component-key="{{key}}"
              data-layout-part="score"
              {{#if scoreDisabled}}disabled{{/if}}
            >

            <input
              class="overlay-field ability-modifier-field"
              type="text"
              value="{{modifierValue}}"
              style="{{modifierStyle}}"
              aria-label="{{label}} modifier"
              data-component-key="{{key}}"
              data-layout-part="modifier"
              readonly
              disabled
            >
          {{/if}}
        {{/each}}
      </div>


    </div>
  {{/each}}
</form>
