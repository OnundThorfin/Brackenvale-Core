<form class="brackenvale-sheet-form {{cssClass}}" autocomplete="off">

  {{!-- =====================================================
       CHARACTER HEADER
       ===================================================== --}}

  <header class="brackenvale-sheet-header">
    <div class="brackenvale-portrait">
      <img
        src="{{actor.img}}"
        data-edit="img"
        alt="{{actor.name}}"
      >
    </div>

    <div class="brackenvale-identity">
      <label>Character Name</label>
      <input
        class="brackenvale-character-name"
        type="text"
        name="name"
        value="{{actor.name}}"
      >

      <div class="brackenvale-identity-grid">
        <div>
          <label>Class & Level</label>
          <input type="text" name="flags.brackenvale-core.classLevel">
        </div>

        <div>
          <label>Background</label>
          <input type="text" name="flags.brackenvale-core.background">
        </div>

        <div>
          <label>Species</label>
          <input type="text" name="flags.brackenvale-core.species">
        </div>

        <div>
          <label>Culture</label>
          <input type="text" name="flags.brackenvale-core.culture">
        </div>
      </div>
    </div>
  </header>

  {{!-- =====================================================
       PAGE NAVIGATION
       ===================================================== --}}

  <nav class="brackenvale-sheet-tabs" aria-label="Character Sheet Pages">
    <button type="button" class="active" data-page="page-one">
      1. Character
    </button>

    <button type="button" data-page="page-two">
      2. Details
    </button>

    <button type="button" data-page="page-three">
      3. Equipment
    </button>

    <button type="button" data-page="page-four">
      4. Spells
    </button>
  </nav>

  <main class="brackenvale-sheet-pages">

    {{!-- ===================================================
         PAGE ONE — CHARACTER & COMBAT
         =================================================== --}}

    <section class="brackenvale-page active" data-page="page-one">

      <div class="page-one-grid">

        <aside class="abilities-column">

          <section class="sheet-panel ability-panel">
            <h2>Abilities</h2>

            {{#each abilities as |ability key|}}
              <div class="ability-block">
                <button
                  type="button"
                  class="ability-roll"
                  data-ability="{{key}}"
                >
                  {{ability.label}}
                </button>

                <input
                  class="ability-score"
                  type="number"
                  name="system.abilities.{{key}}.value"
                  value="{{ability.value}}"
                >

                <div class="ability-modifier">
                  {{numberFormat ability.mod decimals=0 sign=true}}
                </div>

                <label class="saving-throw">
                  <input
                    type="checkbox"
                    name="system.abilities.{{key}}.proficient"
                    {{checked ability.proficient}}
                  >
                  Save {{numberFormat ability.save decimals=0 sign=true}}
                </label>
              </div>
            {{/each}}
          </section>

          <section class="sheet-panel">
            <h2>Languages</h2>

            <div class="lined-fields five-lines">
              <input type="text" name="flags.brackenvale-core.languages.0">
              <input type="text" name="flags.brackenvale-core.languages.1">
              <input type="text" name="flags.brackenvale-core.languages.2">
              <input type="text" name="flags.brackenvale-core.languages.3">
              <input type="text" name="flags.brackenvale-core.languages.4">
            </div>

            <label class="checkbox-row">
              <input
                type="checkbox"
                name="flags.brackenvale-core.illiterate"
              >
              Illiterate
            </label>
          </section>

        </aside>

        <section class="skills-column sheet-panel">
          <h2>Skills</h2>

          <div class="skill-list">
            {{#each skills as |skill key|}}
              <div class="skill-row">
                <input
                  type="checkbox"
                  name="system.skills.{{key}}.value"
                  {{checked skill.proficient}}
                >

                <button
                  type="button"
                  class="skill-roll"
                  data-skill="{{key}}"
                >
                  {{skill.label}}
                </button>

                <span>
                  {{numberFormat skill.total decimals=0 sign=true}}
                </span>
              </div>
            {{/each}}
          </div>

          <div class="passive-scores">
            <div>
              <label>Passive Perception</label>
              <input type="number" name="flags.brackenvale-core.passivePerception">
            </div>

            <div>
              <label>Passive Investigation</label>
              <input type="number" name="flags.brackenvale-core.passiveInvestigation">
            </div>

            <div>
              <label>Passive Insight</label>
              <input type="number" name="flags.brackenvale-core.passiveInsight">
            </div>
          </div>
        </section>

        <section class="combat-column">

          <div class="combat-stat-grid">

            <div class="stat-box">
              <label>Armor Class</label>
              <input
                type="number"
                name="system.attributes.ac.value"
                value="{{system.attributes.ac.value}}"
              >
            </div>

            <div class="stat-box">
              <label>Initiative</label>
              <div class="stat-display">
                {{numberFormat system.attributes.init.total decimals=0 sign=true}}
              </div>
            </div>

            <div class="stat-box">
              <label>Speed</label>
              <input
                type="text"
                name="flags.brackenvale-core.speed"
              >
            </div>

            <div class="stat-box">
              <label>Proficiency</label>
              <div class="stat-display">
                +{{system.attributes.prof}}
              </div>
            </div>

          </div>

          <section class="sheet-panel hit-points-panel">
            <h2>Hit Points</h2>

            <div class="hit-point-grid">
              <div>
                <label>Current</label>
                <input
                  type="number"
                  name="system.attributes.hp.value"
                  value="{{system.attributes.hp.value}}"
                >
              </div>

              <div>
                <label>Maximum</label>
                <input
                  type="number"
                  name="system.attributes.hp.max"
                  value="{{system.attributes.hp.max}}"
                >
              </div>

              <div>
                <label>Temporary</label>
                <input
                  type="number"
                  name="system.attributes.hp.temp"
                  value="{{system.attributes.hp.temp}}"
                >
              </div>
            </div>

            <div class="recovery-grid">
              <div>
                <label>Hit Dice</label>
                <input type="text" name="flags.brackenvale-core.hitDice">
              </div>

              <div>
                <label>Death Saves</label>
                <div class="death-save-row">
                  <span>Successes</span>
                  <input type="checkbox">
                  <input type="checkbox">
                  <input type="checkbox">
                </div>

                <div class="death-save-row">
                  <span>Failures</span>
                  <input type="checkbox">
                  <input type="checkbox">
                  <input type="checkbox">
                </div>
              </div>
            </div>
          </section>

          <section class="sheet-panel">
            <h2>Weapons</h2>

            <div class="weapon-table">
              <div class="weapon-heading">
                <span>Weapon</span>
                <span>Attack</span>
                <span>Damage</span>
                <span>Condition</span>
              </div>

              {{#each weapons as |weapon|}}
                <div class="weapon-row item-row" data-item-id="{{weapon.id}}">
                  <button
                    type="button"
                    class="item-name item-roll"
                    data-item-id="{{weapon.id}}"
                  >
                    {{weapon.name}}
                  </button>

                  <span>{{weapon.attack}}</span>
                  <span>{{weapon.damage}}</span>

                  <div class="condition-boxes">
                    <input type="checkbox">
                    <input type="checkbox">
                    <input type="checkbox">
                  </div>
                </div>
              {{/each}}

              {{#unless weapons.length}}
                <div class="empty-row">No weapons equipped.</div>
              {{/unless}}
            </div>
          </section>

          <div class="armor-supply-grid">

            <section class="sheet-panel">
              <h2>Armor & Shield</h2>

              <div class="condition-entry">
                <label>Armor</label>
                <input type="text" name="flags.brackenvale-core.armorName">

                <div class="condition-boxes">
                  <input type="checkbox">
                  <input type="checkbox">
                  <input type="checkbox">
                </div>
              </div>

              <div class="condition-entry">
                <label>Shield</label>
                <input type="text" name="flags.brackenvale-core.shieldName">

                <div class="condition-boxes">
                  <input type="checkbox">
                  <input type="checkbox">
                  <input type="checkbox">
                </div>
              </div>
            </section>

            <section class="sheet-panel">
              <h2>Supplies</h2>

              <div class="supply-die">
                <label>Supply Die</label>

                <select name="flags.brackenvale-core.supplyDie">
                  <option value="d12">d12</option>
                  <option value="d10">d10</option>
                  <option value="d8">d8</option>
                  <option value="d6">d6</option>
                  <option value="d4">d4</option>
                  <option value="depleted">Depleted</option>
                </select>
              </div>

              <div class="lined-fields compact-lines">
                <input type="text" name="flags.brackenvale-core.supplies.0">
                <input type="text" name="flags.brackenvale-core.supplies.1">
                <input type="text" name="flags.brackenvale-core.supplies.2">
              </div>
            </section>

          </div>

          <section class="sheet-panel experience-panel">
            <h2>Experience</h2>

            <div class="experience-grid">
              <div>
                <label>Current XP</label>
                <input
                  type="number"
                  name="system.details.xp.value"
                  value="{{system.details.xp.value}}"
                >
              </div>

              <div>
                <label>Next Level</label>
                <input
                  type="number"
                  name="system.details.xp.max"
                  value="{{system.details.xp.max}}"
                >
              </div>
            </div>
          </section>

        </section>

      </div>
    </section>

    {{!-- ===================================================
         PAGE TWO — CHARACTER DETAILS
         =================================================== --}}

    <section class="brackenvale-page" data-page="page-two">

      <div class="page-two-grid">

        <section class="sheet-panel proficiencies-panel">
          <h2>Proficiencies</h2>

          <div class="proficiency-section">
            <h3>Armor</h3>
            <textarea name="flags.brackenvale-core.proficiencies.armor"></textarea>
          </div>

          <div class="proficiency-section">
            <h3>Weapons</h3>
            <textarea name="flags.brackenvale-core.proficiencies.weapons"></textarea>
          </div>

          <div class="proficiency-section">
            <h3>Tools</h3>
            <textarea name="flags.brackenvale-core.proficiencies.tools"></textarea>
          </div>

          <div class="proficiency-section">
            <h3>Other Training</h3>
            <textarea name="flags.brackenvale-core.proficiencies.other"></textarea>
          </div>
        </section>

        <section class="character-drives">

          <section class="sheet-panel drive-panel belief-panel">
            <h2>Belief</h2>
            <textarea
              class="three-line-textarea"
              name="flags.brackenvale-core.belief"
            ></textarea>
          </section>

          <section class="sheet-panel drive-panel goal-panel">
            <h2>Goal</h2>
            <textarea
              class="three-line-textarea"
              name="flags.brackenvale-core.goal"
            ></textarea>
          </section>

          <section class="sheet-panel drive-panel">
            <h2>Instinct</h2>
            <textarea
              class="two-line-textarea"
              name="flags.brackenvale-core.instinct"
            ></textarea>
          </section>

          <section class="sheet-panel drive-panel">
            <h2>Flaw</h2>
            <textarea
              class="two-line-textarea"
              name="flags.brackenvale-core.flaw"
            ></textarea>
          </section>

          <section class="sheet-panel">
            <h2>Character Notes</h2>
            <textarea
              class="large-notes"
              name="flags.brackenvale-core.characterNotes"
            ></textarea>
          </section>

        </section>

        <section class="sheet-panel features-panel">
          <h2>Features & Traits</h2>

          <div class="feature-list">
            {{#each features as |feature|}}
              <div class="feature-row item-row" data-item-id="{{feature.id}}">
                <button
                  type="button"
                  class="item-name item-open"
                  data-item-id="{{feature.id}}"
                >
                  {{feature.name}}
                </button>

                <span>{{feature.source}}</span>
              </div>
            {{/each}}

            {{#unless features.length}}
              <div class="empty-row">No features recorded.</div>
            {{/unless}}
          </div>
        </section>

      </div>
    </section>

    {{!-- ===================================================
         PAGE THREE — EQUIPMENT
         =================================================== --}}

    <section class="brackenvale-page" data-page="page-three">

      <div class="page-three-grid">

        <section class="equipment-left">

          <section class="sheet-panel">
            <h2>Armor, Shield & Weapons</h2>

            <div class="equipment-lines five-equipment-lines">
              {{#each weaponSlots as |slot|}}
                <div class="equipment-line">
                  <input type="text" value="{{slot.name}}">
                  <input
                    class="slot-box"
                    type="text"
                    value="{{slot.slots}}"
                    aria-label="Slots"
                  >
                </div>
              {{/each}}
            </div>
          </section>

          <section class="sheet-panel">
            <h2>Worn Equipment</h2>

            <div class="equipment-lines ten-equipment-lines">
              {{#each wornSlots as |slot|}}
                <div class="equipment-line">
                  <input type="text" value="{{slot.name}}">
                  <input
                    class="slot-box"
                    type="text"
                    value="{{slot.slots}}"
                    aria-label="Slots"
                  >
                </div>
              {{/each}}
            </div>
          </section>

        </section>

        <section class="equipment-right">

          <div class="currency-supply-row">

            <section class="sheet-panel currency-panel">
              <h2>Currency</h2>

              <div class="currency-grid">
                <label>
                  CP
                  <input
                    type="number"
                    name="system.currency.cp"
                    value="{{system.currency.cp}}"
                  >
                </label>

                <label>
                  SP
                  <input
                    type="number"
                    name="system.currency.sp"
                    value="{{system.currency.sp}}"
                  >
                </label>

                <label>
                  EP
                  <input
                    type="number"
                    name="system.currency.ep"
                    value="{{system.currency.ep}}"
                  >
                </label>

                <label>
                  GP
                  <input
                    type="number"
                    name="system.currency.gp"
                    value="{{system.currency.gp}}"
                  >
                </label>

                <label>
                  PP
                  <input
                    type="number"
                    name="system.currency.pp"
                    value="{{system.currency.pp}}"
                  >
                </label>
              </div>
            </section>

            <section class="sheet-panel pack-supplies-panel">
              <h2>Supplies</h2>

              <select name="flags.brackenvale-core.supplyDie">
                <option value="d12">d12</option>
                <option value="d10">d10</option>
                <option value="d8">d8</option>
                <option value="d6">d6</option>
                <option value="d4">d4</option>
                <option value="depleted">Depleted</option>
              </select>

              <input
                type="text"
                name="flags.brackenvale-core.supplyNotes"
                placeholder="Notes"
              >
            </section>

          </div>

          <section class="sheet-panel packed-gear-panel">
            <h2>Packed Gear</h2>

            <div class="packed-gear-columns">

              <div class="packed-gear-column">
                {{#each packedGearLeft as |slot|}}
                  <div class="equipment-line">
                    <input type="text" value="{{slot.name}}">
                    <input
                      class="slot-box"
                      type="text"
                      value="{{slot.slots}}"
                      aria-label="Slots"
                    >
                  </div>
                {{/each}}
              </div>

              <div class="packed-gear-column">
                {{#each packedGearRight as |slot|}}
                  <div class="equipment-line">
                    <input type="text" value="{{slot.name}}">
                    <input
                      class="slot-box"
                      type="text"
                      value="{{slot.slots}}"
                      aria-label="Slots"
                    >
                  </div>
                {{/each}}
              </div>

            </div>

            <div class="encumbrance-summary">
              <label>
                Equipped
                <input type="number" name="flags.brackenvale-core.equippedSlots">
                / 10
              </label>

              <label>
                Packed
                <input type="number" name="flags.brackenvale-core.packedSlots">
                / 16
              </label>
            </div>
          </section>

        </section>

      </div>
    </section>

    {{!-- ===================================================
         PAGE FOUR — SPELLCASTING
         =================================================== --}}

    <section class="brackenvale-page" data-page="page-four">

      <section class="spellcasting-header sheet-panel">
        <h2>Spellcasting</h2>

        <div class="spellcasting-stat-grid">

          <div>
            <label>Spellcasting Class</label>
            <input type="text" name="flags.brackenvale-core.spellcastingClass">
          </div>

          <div>
            <label>Ability</label>
            <input
              type="text"
              name="flags.brackenvale-core.spellcastingAbility"
            >
          </div>

          <div>
            <label>Spell Save DC</label>
            <input
              type="number"
              name="flags.brackenvale-core.spellSaveDC"
            >
          </div>

          <div>
            <label>Spell Attack</label>
            <input
              type="text"
              name="flags.brackenvale-core.spellAttack"
            >
          </div>

        </div>
      </section>

      <div class="page-four-grid">

        <section class="sheet-panel cantrip-panel">
          <h2>Cantrips</h2>

          <div class="spell-column">
            {{#each cantrips as |spell|}}
              <div class="spell-row item-row" data-item-id="{{spell.id}}">
                <button
                  type="button"
                  class="spell-name item-roll"
                  data-item-id="{{spell.id}}"
                >
                  {{spell.name}}
                </button>

                <span class="spell-markers">
                  <label title="Concentration">
                    C
                    <input type="checkbox" {{checked spell.concentration}}>
                  </label>

                  <label title="Ritual">
                    R
                    <input type="checkbox" {{checked spell.ritual}}>
                  </label>

                  <label title="Material">
                    M
                    <input type="checkbox" {{checked spell.material}}>
                  </label>
                </span>
              </div>
            {{/each}}

            {{#each cantripBlanks}}
              <div class="spell-row blank-spell-row">
                <input type="text">
                <span class="spell-markers">
                  <label>C <input type="checkbox"></label>
                  <label>R <input type="checkbox"></label>
                  <label>M <input type="checkbox"></label>
                </span>
              </div>
            {{/each}}
          </div>
        </section>

        <section class="sheet-panel prepared-spells-panel">
          <h2>Prepared Spells</h2>

          <div class="prepared-spell-columns">

            <div class="spell-column">
              {{#each preparedSpellsLeft as |spell|}}
                <div class="spell-row item-row" data-item-id="{{spell.id}}">
                  <span class="spell-level">{{spell.level}}</span>

                  <button
                    type="button"
                    class="spell-name item-roll"
                    data-item-id="{{spell.id}}"
                  >
                    {{spell.name}}
                  </button>

                  <span class="spell-markers">
                    <label>C <input type="checkbox" {{checked spell.concentration}}></label>
                    <label>R <input type="checkbox" {{checked spell.ritual}}></label>
                    <label>M <input type="checkbox" {{checked spell.material}}></label>
                  </span>
                </div>
              {{/each}}
            </div>

            <div class="spell-column">
              {{#each preparedSpellsRight as |spell|}}
                <div class="spell-row item-row" data-item-id="{{spell.id}}">
                  <span class="spell-level">{{spell.level}}</span>

                  <button
                    type="button"
                    class="spell-name item-roll"
                    data-item-id="{{spell.id}}"
                  >
                    {{spell.name}}
                  </button>

                  <span class="spell-markers">
                    <label>C <input type="checkbox" {{checked spell.concentration}}></label>
                    <label>R <input type="checkbox" {{checked spell.ritual}}></label>
                    <label>M <input type="checkbox" {{checked spell.material}}></label>
                  </span>
                </div>
              {{/each}}
            </div>

          </div>
        </section>

      </div>

      <section class="sheet-panel spell-slots-panel">
        <h2>Spell Slots</h2>

        <div class="spell-slot-grid">
          {{#each spellSlots as |slot level|}}
            <div class="spell-slot-level">
              <label>Level {{level}}</label>

              <div>
                <input
                  type="number"
                  name="system.spells.spell{{level}}.value"
                  value="{{slot.value}}"
                >

                <span>/</span>

                <input
                  type="number"
                  name="system.spells.spell{{level}}.max"
                  value="{{slot.max}}"
                >
              </div>
            </div>
          {{/each}}
        </div>
      </section>

    </section>

  </main>
</form>