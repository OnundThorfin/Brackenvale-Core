<form class="brackenvale-art-sheet {{cssClass}}" autocomplete="off">
  <nav class="brackenvale-page-tabs" aria-label="Character sheet pages">
    <div class="brackenvale-page-buttons">
      {{#each pages}}
        <button
          type="button"
          class="{{#if active}}active{{/if}}"
          data-page="{{page}}"
        >
          {{page}}
        </button>
      {{/each}}
    </div>

    {{#if isGM}}
      <div class="brackenvale-layout-tools">
        <button type="button" data-action="toggle-calibration">
          Calibrate
        </button>
        <button type="button" data-action="export-layout">
          Export Page JSON
        </button>
        <span class="brackenvale-calibration-status" aria-live="polite">
          No field selected
        </span>
      </div>
    {{/if}}
  </nav>

  {{#each pages}}
    <div
      class="brackenvale-art-page {{#if active}}active{{/if}}"
      data-page="{{page}}"
    >
      <img
        class="brackenvale-page-art"
        src="{{art}}"
        alt=""
        draggable="false"
      >

      <div class="brackenvale-page-fields">
        {{#each components}}
          {{#if isTextField}}
            <input
              class="overlay-field {{className}}"
              type="{{inputType}}"
              name="{{name}}"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{#if readonly}}readonly{{/if}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isItemSummary}}
            <input
              class="overlay-field {{className}} item-summary-field"
              type="text"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              title="Double-click to open the native D&D item"
              data-item-id="{{itemId}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              readonly
            >
          {{/if}}

          {{#if isCheckboxField}}
            <input
              class="overlay-field {{className}}"
              type="checkbox"
              name="{{name}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{checked checked}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isRollRow}}
            <div
              class="overlay-field {{className}} proficiency-rank-{{proficiencyRank}}"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
            >
              <button
                type="button"
                class="ability-roll-proficiency"
                aria-label="Change {{label}} proficiency"
                title="{{#if proficiencyEditable}}Click to cycle proficiency{{else}}Unlock the sheet to change proficiency{{/if}}"
                data-action="cycle-proficiency"
                data-path="{{proficiencyPath}}"
                data-rank="{{proficiencyRank}}"
                data-maximum-rank="{{maximumRank}}"
                {{#unless proficiencyEditable}}disabled{{/unless}}
              ></button>

              <button
                type="button"
                class="ability-roll-button"
                aria-label="{{label}}"
                title="Roll {{label}}"
                data-roll-type="{{rollType}}"
                data-roll-key="{{rollKey}}"
              >
                <span class="ability-roll-modifier">{{modifierValue}}</span>
              </button>
            </div>
          {{/if}}

          {{#if isHitDiceSummary}}
            <div
              class="overlay-field hit-dice-summary"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              <button
                type="button"
                class="hit-dice-denomination"
                data-action="edit-hit-dice-class"
                data-item-id="{{itemId}}"
                title="Open class and Hit Dice settings"
                {{#unless itemId}}disabled{{/unless}}
              >{{denomination}}</button>

              <button
                type="button"
                class="hit-dice-total"
                data-action="edit-hit-dice-class"
                data-item-id="{{itemId}}"
                title="Total Hit Dice comes from class level"
                {{#unless itemId}}disabled{{/unless}}
              >{{total}}</button>

              <input
                class="hit-dice-used"
                type="number"
                min="0"
                max="{{total}}"
                value="{{used}}"
                data-action="update-hit-dice-used"
                data-item-id="{{itemId}}"
                data-item-path="{{usedPath}}"
                aria-label="Used Hit Dice"
                title="Used Hit Dice"
                {{#unless editable}}disabled{{/unless}}
              >
            </div>
          {{/if}}

          {{#if isDeathSaveRow}}
            <div
              class="overlay-field death-save-row-component"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              {{#each dots}}
                <button
                  type="button"
                  class="death-save-dot {{#if filled}}filled{{/if}}"
                  data-action="set-death-save"
                  data-path="{{../path}}"
                  data-value="{{value}}"
                  aria-label="Set {{../label}} to {{value}}"
                  {{#unless ../editable}}disabled{{/unless}}
                ></button>
              {{/each}}
            </div>
          {{/if}}

          {{#if isWeaponTable}}
            <div
              class="overlay-field weapon-table-component"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              {{#each weapons}}
                <div
                  class="weapon-table-row {{#unless id}}empty{{/unless}}"
                  data-item-id="{{id}}"
                >
                  <button
                    type="button"
                    class="weapon-cell weapon-name"
                    data-action="edit-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Open weapon item{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{name}}</button>

                  <button
                    type="button"
                    class="weapon-cell weapon-attack"
                    data-action="use-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Use this weapon{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{attack}}</button>

                  <button
                    type="button"
                    class="weapon-cell weapon-damage"
                    data-action="use-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Use this weapon{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{damage}}</button>

                  <button
                    type="button"
                    class="weapon-cell weapon-mastery"
                    data-action="edit-weapon"
                    data-item-id="{{id}}"
                    title="{{#if id}}Open weapon item{{/if}}"
                    {{#unless id}}disabled{{/unless}}
                  >{{mastery}}</button>

                  <div class="weapon-condition" aria-label="{{#if id}}Weapon condition{{/if}}">
                    {{#each conditionDots}}
                      <button
                        type="button"
                        class="weapon-condition-dot {{#if filled}}filled{{/if}}"
                        data-action="set-weapon-condition"
                        data-item-id="{{../id}}"
                        data-value="{{value}}"
                        aria-label="Set weapon condition to {{value}}"
                        {{#unless ../id}}disabled{{/unless}}
                      ></button>
                    {{/each}}
                  </div>
                </div>
              {{/each}}
            </div>
          {{/if}}

          {{#if isAbilityScore}}
            <input
              class="overlay-field ability-score-field"
              type="number"
              name="{{scoreName}}"
              value="{{scoreValue}}"
              style="{{scoreStyle}}"
              aria-label="{{label}} score"
              data-component-key="{{key}}"
              data-layout-part="score"
              {{#if scoreDisabled}}disabled{{/if}}
            >

            <input
              class="overlay-field ability-modifier-field"
              type="text"
              value="{{modifierValue}}"
              style="{{modifierStyle}}"
              aria-label="{{label}} modifier"
              data-component-key="{{key}}"
              data-layout-part="modifier"
              readonly
              disabled
            >
          {{/if}}
        {{/each}}
      </div>
    </div>
  {{/each}}
</form>
