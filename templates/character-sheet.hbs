<form class="brackenvale-art-sheet {{cssClass}}" autocomplete="off">
  <nav class="brackenvale-page-tabs" aria-label="Character sheet pages">
    <div class="brackenvale-page-buttons">
      {{#each pages}}
        <button
          type="button"
          class="{{#if active}}active{{/if}}"
          data-page="{{page}}"
        >
          {{page}}
        </button>
      {{/each}}
    </div>

    {{#if isGM}}
      <div class="brackenvale-layout-tools">
        <button type="button" data-action="toggle-calibration">
          Calibrate
        </button>
        <button type="button" data-action="export-layout">
          Export Page JSON
        </button>
        <span class="brackenvale-calibration-status" aria-live="polite">
          No field selected
        </span>
      </div>
    {{/if}}
  </nav>

  {{#each pages}}
    <div
      class="brackenvale-art-page {{#if active}}active{{/if}}"
      data-page="{{page}}"
    >
      <img
        class="brackenvale-page-art"
        src="{{art}}"
        alt=""
        draggable="false"
      >

      <div class="brackenvale-page-fields">
        {{#each components}}
          {{#if isTextField}}
            <input
              class="overlay-field {{className}}"
              type="{{inputType}}"
              name="{{name}}"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{#if readonly}}readonly{{/if}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isItemSummary}}
            <input
              class="overlay-field {{className}} item-summary-field"
              type="text"
              value="{{value}}"
              style="{{style}}"
              aria-label="{{label}}"
              title="Double-click to open the native D&D item"
              data-item-id="{{itemId}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              readonly
            >
          {{/if}}

          {{#if isCheckboxField}}
            <input
              class="overlay-field {{className}}"
              type="checkbox"
              name="{{name}}"
              style="{{style}}"
              aria-label="{{label}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              {{checked checked}}
              {{#if disabled}}disabled{{/if}}
            >
          {{/if}}

          {{#if isRollRow}}
            <div
              class="overlay-field {{className}} proficiency-rank-{{proficiencyRank}}"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
            >
              <button
                type="button"
                class="ability-roll-proficiency"
                aria-label="Change {{label}} proficiency"
                title="{{#if proficiencyEditable}}Click to cycle proficiency{{else}}Unlock the sheet to change proficiency{{/if}}"
                data-action="cycle-proficiency"
                data-path="{{proficiencyPath}}"
                data-rank="{{proficiencyRank}}"
                data-maximum-rank="{{maximumRank}}"
                {{#unless proficiencyEditable}}disabled{{/unless}}
              ></button>

              <button
                type="button"
                class="ability-roll-button"
                aria-label="{{label}}"
                title="Roll {{label}}"
                data-roll-type="{{rollType}}"
                data-roll-key="{{rollKey}}"
              >
                <span class="ability-roll-modifier">{{modifierValue}}</span>
              </button>
            </div>
          {{/if}}

          {{#if isHitDiceSummary}}
            <div
              class="overlay-field hit-dice-summary"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              <span class="hit-dice-denomination">{{denomination}}</span>
              <span class="hit-dice-total">{{total}}</span>
              <span class="hit-dice-used">{{used}}</span>
            </div>
          {{/if}}

          {{#if isDeathSaves}}
            <div
              class="overlay-field death-saves-component"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              <div class="death-save-row successes">
                {{#each (range 1 4)}}
                  <button
                    type="button"
                    class="death-save-dot {{#if (lte this ../successes)}}filled{{/if}}"
                    data-action="set-death-save"
                    data-path="system.attributes.death.success"
                    data-value="{{this}}"
                    aria-label="Set death save successes to {{this}}"
                    {{#unless ../editable}}disabled{{/unless}}
                  ></button>
                {{/each}}
              </div>
              <div class="death-save-row failures">
                {{#each (range 1 4)}}
                  <button
                    type="button"
                    class="death-save-dot {{#if (lte this ../failures)}}filled{{/if}}"
                    data-action="set-death-save"
                    data-path="system.attributes.death.failure"
                    data-value="{{this}}"
                    aria-label="Set death save failures to {{this}}"
                    {{#unless ../editable}}disabled{{/unless}}
                  ></button>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if isWeaponTable}}
            <div
              class="overlay-field weapon-table-component"
              style="{{style}}"
              data-component-key="{{key}}"
              data-layout-part="root"
              aria-label="{{label}}"
            >
              {{#each weapons}}
                <button
                  type="button"
                  class="weapon-table-row {{#unless id}}empty{{/unless}}"
                  data-item-id="{{id}}"
                  title="{{#if id}}Click to use; right-click to edit{{/if}}"
                  {{#unless id}}disabled{{/unless}}
                >
                  <span class="weapon-name">{{name}}</span>
                  <span class="weapon-attack">{{attack}}</span>
                  <span class="weapon-damage">{{damage}}</span>
                  <span class="weapon-mastery">{{mastery}}</span>
                </button>
              {{/each}}
            </div>
          {{/if}}

          {{#if isAbilityScore}}
            <input
              class="overlay-field ability-score-field"
              type="number"
              name="{{scoreName}}"
              value="{{scoreValue}}"
              style="{{scoreStyle}}"
              aria-label="{{label}} score"
              data-component-key="{{key}}"
              data-layout-part="score"
              {{#if scoreDisabled}}disabled{{/if}}
            >

            <input
              class="overlay-field ability-modifier-field"
              type="text"
              value="{{modifierValue}}"
              style="{{modifierStyle}}"
              aria-label="{{label}} modifier"
              data-component-key="{{key}}"
              data-layout-part="modifier"
              readonly
              disabled
            >
          {{/if}}
        {{/each}}
      </div>
    </div>
  {{/each}}
</form>
